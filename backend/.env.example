# Canton JSON Ledger API base URL (v2)
CANTON_LEDGER_API_URL=http://localhost:7575

# Package name as uploaded to Canton (used in template IDs)
CANTON_PACKAGE_NAME=collateral-eligibility-review

# Party identifiers (full Canton party IDs — set after party allocation)
PARTY_OPERATING_TEAM=OperatingTeam::xxxx
PARTY_CUSTODIAN=Custodian::xxxx
PARTY_LEGAL=LegalCounsel::xxxx
PARTY_COMPLIANCE=ComplianceProvider::xxxx

# User IDs for acting-as (must match Setup.daml createUser calls)
USER_OPERATING_TEAM=operatingteam
USER_CUSTODIAN=custodian
USER_LEGAL=legalcounsel
USER_COMPLIANCE=complianceprovider
