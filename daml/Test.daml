module Test where

import Daml.Script
import CollateralReview.Main

data TestParties = TestParties with
  opTeam : Party
  cust   : Party
  legal  : Party
  comp   : Party

allocateTestParties : Script TestParties
allocateTestParties = script do
  opTeam <- allocateParty "OperatingTeam"
  cust <- allocateParty "Custodian"
  legal <- allocateParty "LegalCounsel"
  comp <- allocateParty "ComplianceProvider"
  return TestParties with ..

createCaseWithTasks : TestParties -> Script (ContractId CollateralReviewCase, ContractId ReviewTask, ContractId ReviewTask, ContractId ReviewTask)
createCaseWithTasks TestParties{..} = do
  now <- getTime
  caseCid <- submit opTeam do
    createCmd CollateralReviewCase with
      operatingTeam = opTeam, custodian = cust, legalCounsel = legal, complianceProvider = comp
      assetId = "PCN-TEST-001", assetType = "Private Credit Note", issuer = "Test Issuer"
      maturity = "2027-01-01", coupon = "5.00%", status = UnderReview
      tasksCreated = False
      auditLog = [AuditEntry "CaseCreated" opTeam now]
  (caseCid', custTask, legalTask, compTask) <- submit opTeam do exerciseCmd caseCid CreateReviewTasks
  return (caseCid', custTask, legalTask, compTask)

-- | Submit all 3 reviews and return result CIDs.
submitAllApprovals : TestParties -> (ContractId ReviewTask, ContractId ReviewTask, ContractId ReviewTask) -> Script (ContractId ReviewResult, ContractId ReviewResult, ContractId ReviewResult)
submitAllApprovals TestParties{..} (custTask, legalTask, compTask) = do
  custResult <- submit cust do exerciseCmd custTask SubmitReview with decision = Approve, rationale = "OK"
  legalResult <- submit legal do exerciseCmd legalTask SubmitReview with decision = Approve, rationale = "OK"
  compResult <- submit comp do exerciseCmd compTask SubmitReview with decision = Approve, rationale = "OK"
  return (custResult, legalResult, compResult)

-- | 1. Happy path: all 3 approve → Eligible.
testHappyPath : Script ()
testHappyPath = script do
  parties@TestParties{..} <- allocateTestParties
  (caseCid, custTask, legalTask, compTask) <- createCaseWithTasks parties
  (custR, legalR, compR) <- submitAllApprovals parties (custTask, legalTask, compTask)
  decisionCid <- submit opTeam do
    exerciseCmd caseCid FinalizeDecision with
      custodianResultCid = custR, legalResultCid = legalR, complianceResultCid = compR
  Some decision <- queryContractId opTeam decisionCid
  assertMsg "Should be Eligible" (decision.status == Eligible)
  assertMsg "Audit log should have 5 entries" (length decision.auditLog == 5)
  debug "✓ Happy path passed"

-- | 2. Rejection: one rejects → Ineligible.
testRejection : Script ()
testRejection = script do
  parties@TestParties{..} <- allocateTestParties
  (caseCid, custTask, legalTask, compTask) <- createCaseWithTasks parties
  custR <- submit cust do exerciseCmd custTask SubmitReview with decision = Approve, rationale = "OK"
  legalR <- submit legal do exerciseCmd legalTask SubmitReview with decision = Reject, rationale = "Jurisdiction issue"
  compR <- submit comp do exerciseCmd compTask SubmitReview with decision = Approve, rationale = "OK"
  decisionCid <- submit opTeam do
    exerciseCmd caseCid FinalizeDecision with
      custodianResultCid = custR, legalResultCid = legalR, complianceResultCid = compR
  Some decision <- queryContractId opTeam decisionCid
  assertMsg "Should be Ineligible" (decision.status == Ineligible)
  debug "✓ Rejection path passed"

-- | 3. Wrong party: custodian cannot exercise legal's task.
testWrongParty : Script ()
testWrongParty = script do
  parties@TestParties{..} <- allocateTestParties
  (_, _, legalTask, _) <- createCaseWithTasks parties
  submitMustFail cust do exerciseCmd legalTask SubmitReview with decision = Approve, rationale = "Not my role"
  debug "✓ Wrong party correctly rejected"

-- | 4. Privacy: custodian cannot see legal's task.
testPrivacy : Script ()
testPrivacy = script do
  parties@TestParties{..} <- allocateTestParties
  (_, _, legalTask, _) <- createCaseWithTasks parties
  visibleToCust <- queryContractId cust legalTask
  assertMsg "Custodian should not see legal task" (visibleToCust == None)
  debug "✓ Privacy: custodian cannot see legal's task"

-- | 5. Reviewer cannot see the orchestrator case.
testReviewerCannotSeeCase : Script ()
testReviewerCannotSeeCase = script do
  parties@TestParties{..} <- allocateTestParties
  (caseCid, _, _, _) <- createCaseWithTasks parties
  visibleToCust <- queryContractId cust caseCid
  assertMsg "Custodian should not see the case contract" (visibleToCust == None)
  debug "✓ Privacy: reviewer cannot see orchestrator case"

-- | 6. Final decision visible to all parties.
testDecisionVisibility : Script ()
testDecisionVisibility = script do
  parties@TestParties{..} <- allocateTestParties
  (caseCid, custTask, legalTask, compTask) <- createCaseWithTasks parties
  (custR, legalR, compR) <- submitAllApprovals parties (custTask, legalTask, compTask)
  decisionCid <- submit opTeam do
    exerciseCmd caseCid FinalizeDecision with
      custodianResultCid = custR, legalResultCid = legalR, complianceResultCid = compR
  Some _ <- queryContractId opTeam decisionCid
  Some _ <- queryContractId cust decisionCid
  Some _ <- queryContractId legal decisionCid
  Some _ <- queryContractId comp decisionCid
  debug "✓ Decision visible to all parties"

-- | 7. Double submit: reviewer tries to submit twice → fails.
testDoubleSubmit : Script ()
testDoubleSubmit = script do
  parties@TestParties{..} <- allocateTestParties
  (_, custTask, _, _) <- createCaseWithTasks parties
  submit cust do exerciseCmd custTask SubmitReview with decision = Approve, rationale = "First"
  -- Task is consumed after first submit, second attempt should fail
  submitMustFail cust do exerciseCmd custTask SubmitReview with decision = Reject, rationale = "Second"
  debug "✓ Double submit correctly rejected"

-- | 8. Partial state: only 1 reviewer submitted → case still Under Review.
testPartialState : Script ()
testPartialState = script do
  parties@TestParties{..} <- allocateTestParties
  (caseCid, custTask, _, _) <- createCaseWithTasks parties
  submit cust do exerciseCmd custTask SubmitReview with decision = Approve, rationale = "OK"
  Some partialCase <- queryContractId opTeam caseCid
  assertMsg "Status should still be UnderReview" (partialCase.status == UnderReview)
  debug "✓ Partial state: case remains Under Review"

-- | 9. Duplicate CreateReviewTasks → fails.
testDuplicateCreateTasks : Script ()
testDuplicateCreateTasks = script do
  parties@TestParties{..} <- allocateTestParties
  (caseCid, _, _, _) <- createCaseWithTasks parties
  -- tasksCreated is now True, second call should fail
  submitMustFail opTeam do exerciseCmd caseCid CreateReviewTasks
  debug "✓ Duplicate CreateReviewTasks correctly rejected"
