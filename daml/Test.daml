module Test where

import Daml.Script
import CollateralReview.Main

data TestParties = TestParties with
  opTeam : Party
  cust   : Party
  legal  : Party
  comp   : Party

allocateTestParties : Script TestParties
allocateTestParties = script do
  opTeam <- allocateParty "OperatingTeam"
  cust <- allocateParty "Custodian"
  legal <- allocateParty "LegalCounsel"
  comp <- allocateParty "ComplianceProvider"
  return TestParties with ..

-- | Helper: create case + review tasks.
createCaseWithTasks : TestParties -> Script (ContractId CollateralReviewCase, ContractId ReviewTask, ContractId ReviewTask, ContractId ReviewTask)
createCaseWithTasks TestParties{..} = do
  now <- getTime
  caseCid <- submit opTeam do
    createCmd CollateralReviewCase with
      operatingTeam = opTeam
      custodian = cust
      legalCounsel = legal
      complianceProvider = comp
      assetId = "PCN-TEST-001"
      assetType = "Private Credit Note"
      issuer = "Test Issuer"
      maturity = "2027-01-01"
      coupon = "5.00%"
      status = UnderReview
      auditLog = [AuditEntry "CaseCreated" opTeam now]
  (custTask, legalTask, compTask) <- submit opTeam do
    exerciseCmd caseCid CreateReviewTasks
  return (caseCid, custTask, legalTask, compTask)

-- | Happy path: all approve → Eligible.
testHappyPath : Script ()
testHappyPath = script do
  parties@TestParties{..} <- allocateTestParties
  (caseCid, custTask, legalTask, compTask) <- createCaseWithTasks parties

  -- Each reviewer submits on their own task (can't see others)
  custResult <- submit cust do
    exerciseCmd custTask SubmitReview with decision = Approve, rationale = "Collateral verified"
  legalResult <- submit legal do
    exerciseCmd legalTask SubmitReview with decision = Approve, rationale = "Legal form acceptable"
  compResult <- submit comp do
    exerciseCmd compTask SubmitReview with decision = Approve, rationale = "Review clear"

  -- Operating Team finalizes
  decisionCid <- submit opTeam do
    exerciseCmd caseCid FinalizeDecision with
      custodianDecision = Approve
      legalDecision = Approve
      complianceDecision = Approve

  Some decision <- queryContractId opTeam decisionCid
  assertMsg "Should be Eligible" (decision.status == Eligible)
  assertMsg "Audit log should have 5 entries" (length decision.auditLog == 5)
  debug "✓ Happy path passed"

-- | Rejection: one rejects → Ineligible.
testRejection : Script ()
testRejection = script do
  parties@TestParties{..} <- allocateTestParties
  (caseCid, custTask, legalTask, compTask) <- createCaseWithTasks parties

  submit cust do exerciseCmd custTask SubmitReview with decision = Approve, rationale = "OK"
  submit legal do exerciseCmd legalTask SubmitReview with decision = Reject, rationale = "Jurisdiction issue"
  submit comp do exerciseCmd compTask SubmitReview with decision = Approve, rationale = "Clear"

  decisionCid <- submit opTeam do
    exerciseCmd caseCid FinalizeDecision with
      custodianDecision = Approve, legalDecision = Reject, complianceDecision = Approve

  Some decision <- queryContractId opTeam decisionCid
  assertMsg "Should be Ineligible" (decision.status == Ineligible)
  debug "✓ Rejection path passed"

-- | Wrong party: custodian cannot exercise legal's task.
testWrongParty : Script ()
testWrongParty = script do
  parties@TestParties{..} <- allocateTestParties
  (_, _, legalTask, _) <- createCaseWithTasks parties

  submitMustFail cust do
    exerciseCmd legalTask SubmitReview with decision = Approve, rationale = "Not my role"
  debug "✓ Wrong party correctly rejected"

-- | Privacy: custodian cannot see legal's task contract.
testPrivacy : Script ()
testPrivacy = script do
  parties@TestParties{..} <- allocateTestParties
  (_, _, legalTask, _) <- createCaseWithTasks parties

  -- Custodian should NOT be able to query legal's task
  visibleToCustomer <- queryContractId cust legalTask
  assertMsg "Custodian should not see legal task" (visibleToCustomer == None)
  debug "✓ Privacy: custodian cannot see legal's task"

-- | Privacy: reviewer cannot see the orchestrator case.
testReviewerCannotSeeCase : Script ()
testReviewerCannotSeeCase = script do
  parties@TestParties{..} <- allocateTestParties
  (caseCid, _, _, _) <- createCaseWithTasks parties

  visibleToCust <- queryContractId cust caseCid
  assertMsg "Custodian should not see the case contract" (visibleToCust == None)
  debug "✓ Privacy: reviewer cannot see orchestrator case"

-- | Final decision visible to all parties.
testDecisionVisibility : Script ()
testDecisionVisibility = script do
  parties@TestParties{..} <- allocateTestParties
  (caseCid, custTask, legalTask, compTask) <- createCaseWithTasks parties

  submit cust do exerciseCmd custTask SubmitReview with decision = Approve, rationale = "OK"
  submit legal do exerciseCmd legalTask SubmitReview with decision = Approve, rationale = "OK"
  submit comp do exerciseCmd compTask SubmitReview with decision = Approve, rationale = "OK"

  decisionCid <- submit opTeam do
    exerciseCmd caseCid FinalizeDecision with
      custodianDecision = Approve, legalDecision = Approve, complianceDecision = Approve

  -- All parties should see the final decision
  Some _ <- queryContractId opTeam decisionCid
  Some _ <- queryContractId cust decisionCid
  Some _ <- queryContractId legal decisionCid
  Some _ <- queryContractId comp decisionCid
  debug "✓ Decision visible to all parties"
